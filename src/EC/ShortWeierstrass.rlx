    i32 PublicKeySize := 0
    void* PublicKeyBytes := Curve->SerializePublicKey(PublicKey, &PublicKeySize)

    Print("Public Key (SEC1 Uncompressed):\n")
    for (i32 Index := 0, Index < PublicKeySize, Index++) {
        Print("%B", (PublicKeyBytes As i8*)[Index])
    }
    Print("\n")

    SHA2_256* SHA := new SHA2_256()

    i8[32] Hash
    SHA->Prepare()
    SHA->Update("nuts 9000", 9)
    SHA->Finalize(Hash)

    Print("Message Hash:\n%hexdump\n", Hash, 32)

    BigInteger* MessageHashInteger := BigInteger:FromBytesReversed(Hash, 32)
    SignaturePair* Signature := DSA->Sign(PrivateKey->Reference(), MessageHashInteger->Reference())

    Print("Signature {\n")
    Print("\tR: %bn-base-16\n", Signature->R)
    Print("\tS: %bn-base-16\n", Signature->S)
    Print("}\n")

    i32 DERSize := 0
    void* DER := DSA->SerializeSignatureDER(Signature, &DERSize)

    Print("DER Signature Size: %i\n", DERSize)

    for (i32 Index := 0, Index < DERSize, Index++) {
        Print("%B", (DER As i8*)[Index])
    }

    Print("\n\n")

    SignaturePair* RoundTripSignature := DSA->LoadSignatureDER(DER, DERSize)

    Print("\nRound Trip Signature {\n")
    Print("\tR: %bn-base-16\n", RoundTripSignature->R)
    Print("\tS: %bn-base-16\n", RoundTripSignature->S)
    Print("}\n")

    i8 IsValid := DSA->Verify(PublicKey->Reference(), MessageHashInteger, RoundTripSignature)

    Print("IsValid? %i\n", IsValid)

