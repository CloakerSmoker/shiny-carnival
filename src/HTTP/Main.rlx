
#Require "$/Memory.rlx"
#Require "$/Console.rlx"
#Require "$/Debug.rlx"

declare i8 TrackAllocations(i8)
i8 ALLOCATIONS_ARE_TRACKED := TrackAllocations(false)

declare i8 EnterMetadataHeap()
declare void ExitMetadataHeap(i8)

#Require "./src/CompressedStackTrace.rlx"

#Require "./src/DebugHeap.rlx"

interface IReadStream {
    virtual i8 Peek(i32, void*)
    virtual i8 Advance(i32)
    virtual i8 Read(i32, void*)
}

interface IWriteStream {
    virtual i8 Write(void*, i32)
}

class MemoryStream implements IReadStream, IWriteStream, derives INew {
    void* Buffer
    i32 Length
    i32 Capacity

    define void New(i32 Capacity) {
        this->Buffer := Alloc(Capacity)
        this->Capacity := Capacity
        this->Length := 0
    }

    define void Free() {
        Free(this->Buffer)
        Free(this)
    }

    define i8 Peek(i32 Size, void* Out) {
        Print("Peek(%i) = ", Size)

        if (Size > this->Length) {
            Print("null\n")
            return false
        }

        Print("\n%hexdump\n", this->Buffer, Size)

        MoveMemory(Out, this->Buffer, Size)
        return true
    }

    define i8 Advance(i32 Size) {
        Print("Advance(%i)\n", Size)

        if (Size > this->Length) {
            return false
        }

        this->Length -= Size
        MoveMemory(this->Buffer, this->Buffer + Size, this->Length)
        return true
    }

    define i8 Read(i32 Size, void* Out) {
        Print("Read(%i)\n", Size)

        if (this->Peek(Size, Out)) {
            this->Advance(Size)
            return true
        }

        return false
    }

    define i8 Write(void* Data, i32 Size) {
        Print("Write(%i)\n", Size)

        if (this->Length + Size > this->Capacity) {
            return false
        }

        MoveMemory(this->Buffer + this->Length, Data, Size)
        this->Length += Size
        return true
    }
}

