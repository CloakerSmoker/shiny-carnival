#Require "./src/HTTP/Server.rlx"

class MathRouteHandler implements HTTP::IRouteHandler, derives INew {
    define i32 Handle(HTTP::String* Operation, HTTP::RequestInfo* Request, HTTP::ResponseInfo* Response) {
        Print("MathRouteHandler::Handle(%S)\n", Operation)

        if (Operation->Length = 0) {
            Response->Body := new HTTP::String("Missing operation")
            return 404
        }

        i64 A := 0
        i64 B := 0

        if !(Request->Parameters->GetInteger("a", &A) && Request->Parameters->GetInteger("b", &B)) {
            Response->Body := new HTTP::String("Missing parameters")
            return 404
        }

        i64 Result := 0

        if (Operation->Equals("add")) {
            Result := A + B
        }
        else if (Operation->Equals("subtract")) {
            Result := A - B
        }
        else {
            Operation->Free()
            Response->Body := new HTTP::String("Unknown operation")
            return 404
        }
        
        Operation->Free()
        Response->Body := HTTP::String:Format("%i", Result)
        return 200
    }
}

#Require "./src/Time.rlx"

#Require "./src/TLS/Server.rlx"
#Require "./src/HTTP/TLS.rlx"

define void Main(i32 ArgC, i8** ArgV) {
    DebugHeapMark()

    i32 ListenPort := AToI(ArgV[1]) As i32
    i8* PrivateKeyPath := ArgV[2]
    i8* CertificatePath := ArgV[3]  

    IPV4SocketAddress* Address := new IPV4SocketAddress("0.0.0.0", ListenPort As i16)
    Socket ListenSocket := Socket:New(AF_INET, SOCK_STREAM, IPPROTO_TCP)
    ListenSocket->SetOption(SO_REUSEADDR, 1)

    while (ListenSocket->Bind(Address~>Base, #IPV4SocketAddress)) {
        Print("Failed to bind to port %i, retrying in 5 seconds...\n", ListenPort)
        Sleep(5)
    }

    ListenSocket->Listen(10)

    TLS::Security::ICertificate* Certificate := TLSLoadCertificate(PrivateKeyPath, CertificatePath)

    i32 PublicKeySize := 0
    void* PublicKey := Certificate->GetPublicKey(&PublicKeySize)

    Print("Using Public Key:\n%hexdump\n", PublicKey, PublicKeySize)

    TLS::HTTPSocketServer* SocketServer := new TLS::HTTPSocketServer(ListenSocket, Certificate)
    HTTP::Server* Server := new HTTP::Server(SocketServer)

    HTTP::IRouteHandler* MathHandler := new MathRouteHandler()
    Server->RootRouteDirectory->Add("math", MathHandler)

    DebugHeapMark()

    Print("Starting server on port %i...\n", ListenPort)

    Server->Start()
}